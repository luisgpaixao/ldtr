# METEO SERVICE
get_meteopoints = function(){
URL = "https://api.agroinsider.com/agroinsider/api/palmetrics/meto-points/B8LPnL!_tsF&pM/"
req = GET( URL )
if(is.null(error_code(req))){
return(NULL)
}
reqParse = httr::content(req, as="parsed")
reqParse = parse_null(reqParse, parcelID)
df = do.call(rbind, lapply(reqParse, as.data.frame))
return(df)
}
get_meteodata = function(pointID, str_date, end_date = NULL){
URL = "https://api.agroinsider.com/agroinsider/api/palmetrics/meto-points/B8LPnL!_tsF&pM"
URL = file.path(URL, pointID, str_date)
if(!is.null(end_date)){
URL = file.path(URL, end_date)
}
req = GET( URL )
if(is.null(error_code(req))){
return(NULL)
}
reqParse = httr::content(req, as="parsed")
return(reqParse)
}
# aux function
aux_meteodata_to_df = function(meteodata) {
day = meteodata$payload$days[[1]]
tibble(
date = meteodata$date,
datetime = day$datetime,
temp = day$temp,
tempmax = day$tempmax,
tempmin = day$tempmin,
feelslike = day$feelslike,
feelslikemax = day$feelslikemax,
feelslikemin = day$feelslikemin,
dew = day$dew,
humidity = day$humidity,
pressure = day$pressure,
windspeed = day$windspeed,
windgust = day$windgust,
winddir = day$winddir,
cloudcover = day$cloudcover,
conditions = day$conditions,
icon = day$icon,
description = day$description,
moonphase = day$moonphase,
precip = day$precip,
precipprob = day$precipprob,
snow = day$snow,
snowdepth = day$snowdepth,
sunrise = day$sunrise,
sunset = day$sunset,
sunriseEpoch = day$sunriseEpoch,
sunsetEpoch = day$sunsetEpoch,
datetimeEpoch = day$datetimeEpoch,
precipcover = day$precipcover,
source = day$source,
station = day$stations[[1]],  # first station
latitude = meteodata$payload$latitude,
longitude = meteodata$payload$longitude,
address = meteodata$payload$address,
timezone = meteodata$payload$timezone
)
}
# usa a aux automatico
meteodata_to_df = function(meteodata){
df = map_dfr(meteodata$data, aux_meteodata_to_df)
return(df)
}
check_co2reports = function(acc_id){
# "134399 2025-01-01 2025-12-31 5 RGB missing -10"
# 423
acc = check_Account(acc_id)
today = Sys.Date()
for(i in 1:length(acc)){
parinfo = acc[[i]]
parid = parinfo$parcelID
print(parid)
for( c in 1:length(parinfo$campaigns)){
if(!is.null(parinfo$campaigns[[c]]$cropID)){
if(parinfo$campaigns[[c]]$cropID == "CROP_CO2"){
str = substr(parinfo$campaigns[[c]]$startDate, 1, 10)
end = substr(parinfo$campaigns[[c]]$endDate, 1, 10)
camp_months = seq(as.numeric(strsplit(str, "-")[[1]][2]),
as.numeric(strsplit(end, "-")[[1]][2]),
1)
imgs = check_CO2imgs(parid, str, end)
img_months = imgs[imgs$isFinal == 0, ]$files
img_year = imgs[imgs$isFinal == 1, ]$files
#meses
for(m in camp_months){
if(m<10){
m = paste0("0", m)
}
sel_months = img_months[unlist(lapply(img_months, function(x){
strsplit(strsplit(x, "_")[[1]][2], "-")[[1]][2] == m}
))]
expected = c("ndvi", "ndwi", "radar_vv", "radar_vh")
present = expected[sapply(expected, function(x) any(grepl(x, sel_months)))]
missing = setdiff(expected, present)
if(length(missing)==0){
rgb = check_Tifs(parid, "RGB", strsplit(sel_months[1], "_")[[1]][2],
strsplit(sel_months[1], "_")[[1]][3])
# rgb = check_Tifs(parid, "RGB", str, end)
# ndvi = check_Tifs(parid, "NDVI", str, end)
ndvi = check_Tifs(parid, "NDVI", strsplit(sel_months[1], "_")[[1]][2],
strsplit(sel_months[1], "_")[[1]][3])
if(length(rgb$OriginalImage) == length(ndvi$OriginalImage)){
missing = "Non missing"
}else{
missing = paste0("RGB missing ", length(ndvi$OriginalImage)-length(rgb$OriginalImage))
print(paste(parid, str, end, as.numeric(m), missing, sep = " "))
}
}else{
print(paste(parid, str, end, as.numeric(m), missing, sep = " "))
}
}
}
}
}
}
}
get_allCampaignsFromParcel = function(acc_id, parcel_id=134265){
acc = check_Account(acc_id)
result = lapply(acc, function(p) {
if (p$parcelID == parcel_id) {
sapply(p$campaigns, function(camp) camp$campaignID)
}
})
# Remove NULLs
result = unlist(result)
return(result)
}
# 3763 3764 3765
get_allstatsCampaign = function(acc_id=423, campaign_id=c(3763, 3764, 3765),
out_f = "D:/AgroInsider/Projectos/Temp_Folder/dados_hugoescola"){
index = c("NDVI", "MOISTURE_INDEX")
acc = check_Account(acc_id)
df = data.frame()
for(campid in campaign_id[order(campaign_id)]){
result = lapply(acc, function(p) {
#length(camps[[1]]$campaignID)
camps = p$campaigns
for(i in 1:length(camps)){
if(length(camps[[i]]$campaignID)>0){
if(camps[[i]]$campaignID == campid){
df = c(p$parcelID, camps[[i]]$startDate, camps[[i]]$endDate)
return(df)
}
}
}
})
result = do.call(rbind, result)
result = data.frame(result)
names(result) = c("parcelID", "start", "end")
df = rbind(df, result)
}
uniq_pars = unique(df$parcelID)
for(u in uniq_pars){
stats_df = data.frame()
name = check_Parcel(u)$parcelName
out_name = file.path(out_f, paste0(name, "_", u, ".csv"))
df_sel = df[df$parcelID==u, ]
for(r in 1:nrow(df_sel)){
str = substr(df_sel$start[r], 1, 10)
end = substr(df_sel$end[r], 1, 10)
print(paste(u, str, end, sep = " "))
for(ind in index){
stats = check_Stats(u, ind, str, end)
stats_df = rbind(stats_df, stats)
}
}
stats_sel = stats_df[, !(names(stats_df) %in% c("iws1", "iws2",
"iws3", "originalImage",
"isSen2cor", "imageABS",
"imageREL", "imageAbsUrl",
"imageRelUrl", "originalImageUrl"))]
write.table(stats_sel, out_name, sep = ";", row.names = F)
}
}
###### condominios ### Estados PP #####
bfs = "D:/AgroInsider/Projectos/Skilltech/bfs.csv"
csv_bfs = read.csv2(bfs)
names(csv_bfs)[names(csv_bfs) == "Nº.Projecto"] = "Projeto"
aac = csv_bfs[,c("AAC.ID", "Projeto")]
ff = "C:/Users/LGP/Downloads/condominios.csv"
csv = read.csv2(ff)
csv = left_join(csv, aac, by = c('Projeto'))
# por beneficiario
table_total_ben = data.frame()
for(b in 1:length(unique(csv$Projeto))){
sel_ben = csv[csv$Projeto == unique(csv$Projeto)[b],]
for(i in 1:length(unique(sel_ben$Aviso))){
sel = sel_ben[sel_ben$Aviso == unique(sel_ben$Aviso)[i],]
for(t in 1:length(unique(sel$Tipo.Pedido))){
sel_tipo = sel[sel$Tipo.Pedido==unique(sel$Tipo.Pedido)[t], ]
for(m in 1:length(unique(sel_tipo$Estado.Análise))){
sel_analise = sel_tipo[sel_tipo$Estado.Análise==unique(sel_tipo$Estado.Análise)[m],]
vec = c(unique(sel_ben$Aviso)[i], sel_analise$AAC.ID[1], sel_analise$Projeto[1],
sel_analise$Beneficiário.Final[1], unique(sel$Tipo.Pedido)[t],
unique(sel_tipo$Estado.Análise)[m], nrow(sel_analise), max(sel_analise$Data.Submissão))
table_total_ben = rbind(table_total_ben, vec)
}
}
}
}
